generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(cuid())
  username    String   @unique
  displayName String
  role        String   // "ADMIN" | "USER"
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  leads       Lead[]
  calls       Call[]
  activity    ActivityLog[]
}

model Lead {
  id            String    @id @default(cuid())
  name          String
  contact       String    // phone or email
  hasWebsite    Boolean   @default(false)
  status        String    @default("NEW") // NEW | HOT | WARM | COLD | NOT_INTERESTED | CONVERTED | DO_NOT_CALL
  firstInterest String?   // free text — what the lead initially wanted
  callCount     Int       @default(0)
  lastCalledAt  DateTime?
  assignedToId  String?
  assignedTo    User?     @relation(fields: [assignedToId], references: [id])
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  calls         Call[]
  followUps     FollowUp[]
}

model Call {
  id        String   @id @default(cuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  calledAt  DateTime @default(now())
  notes     String?
}

model FollowUp {
  id        String    @id @default(cuid())
  leadId    String
  lead      Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  slot      Int       // 1, 2, 3, or 4
  scheduledAt DateTime?
  note      String?
  completed Boolean   @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  @@unique([leadId, slot])
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  action    String   // "CALL" | "STATUS_CHANGE" | "FOLLOWUP_SET" | "LEAD_UPLOADED" | "LEAD_ASSIGNED" etc.
  entity    String   // "LEAD" | "USER" | etc.
  entityId  String?
  metadata  String?  // JSON string
  createdAt DateTime @default(now())
}
